# URL base del backend SecureTrace (Spring Boot). El backend escucha en el
# puerto 8080 (default de Spring Boot). NO incluyas /api al final: las rutas
# de la app ya lo agregan (p.ej. /api/auth/login).
#
# Según dónde corras la app:
#   - Emulador Android:   http://10.0.2.2:8080
#   - Simulador iOS:      http://localhost:8080
#   - Dispositivo físico: http://<IP-LAN-de-tu-PC>:8080  (NO uses localhost)
EXPO_PUBLIC_API_URL=http://10.0.2.2:8080

# Google Maps API key — OBLIGATORIA para que el mapa funcione en Android.
# Cómo obtenerla:
#   1. Ir a https://console.cloud.google.com/
#   2. Crear un proyecto o seleccionar uno existente
#   3. Habilitar "Maps SDK for Android"
#   4. APIs & Services → Credentials → Create Credential → API Key
#   5. Pegar la key aquí
# En iOS el mapa funciona sin key usando Apple Maps como fallback.
EXPO_PUBLIC_MAPS_API_KEY=tu-google-maps-api-key-aqui
